# --- Supabase (same variable names & values as ipl_app) ---
# Point both apps at one project, or paste the same three lines from ipl_app’s .env / Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# ^ optional here (finance uses service role on the server only); keep if you share one .env with ipl_app
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Finance app only (ipl_app does not define these) ---
# Admin: full access (settings, players, fees, import/export, snapshots).
FINANCE_TEAM_PASSWORD=change-me
# Expense-only: view dashboard/history and add expenses (optional; omit to disable).
FINANCE_VIEWER_PASSWORD=change-me-viewer
FINANCE_SESSION_SECRET=change-me-to-a-long-random-string

NEXT_PUBLIC_FINANCE_REMOTE=true

# --- Expense push (ntfy: https://ntfy.sh — free app; subscribe to same topic as in Audit) ---
# Optional fallback if Audit → Expense notifications topic is empty (8–64 chars: [a-zA-Z0-9_-]).
# EXPENSE_NTFY_TOPIC=gs11-your-secret-topic
# Optional self-hosted ntfy base (no trailing slash). Default: https://ntfy.sh
# NTFY_BASE_URL=https://ntfy.sh
