# --- Supabase (same variable names & values as ipl_app) ---
# Point both apps at one project, or paste the same three lines from ipl_app’s .env / Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# ^ optional here (finance uses service role on the server only); keep if you share one .env with ipl_app
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Finance app only (ipl_app does not define these) ---
FINANCE_TEAM_PASSWORD=change-me
FINANCE_SESSION_SECRET=change-me-to-a-long-random-string

NEXT_PUBLIC_FINANCE_REMOTE=true
